# ── Soul web environment ────────────────────────────────────────────────────
# Copy this file to  apps/web/.env.local  and fill in values.
#
# DEV MODE NEEDS NOTHING HERE: the web app defaults to the local API and a mock
# "Sign in (dev)" session. Fill these in only for the live Enoki zkLogin cutover.

# Soul API base URL.
NEXT_PUBLIC_API_URL=http://localhost:3004

# Sui network (testnet for build/demo; mainnet at production cutover).
NEXT_PUBLIC_SUI_NETWORK=testnet

# Enoki public key + Google OAuth client id — for the LIVE zkLogin sign-in only
# (dev mode uses a mock session and does NOT need these). Same values as apps/api/.env.
# Enoki: https://portal.enoki.mystenlabs.com   Google: https://console.cloud.google.com
NEXT_PUBLIC_ENOKI_PUBLIC_KEY=enoki_public_88621752eecb387d0a21f8f895db1af4
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
