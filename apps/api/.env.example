# ── Soul API environment ──────────────────────────────────────────────────────
# Copy this file to  apps/api/.env  and fill in values (Bun auto-loads it).
#
# DEV MODE NEEDS NOTHING HERE: with SOUL_LIVE unset, the API runs on in-memory +
# mock adapters — no database, no Sui Stack, no keys. Fill these in only for the
# live cutover (see specs/001-soul-mvp/live-cutover.md).
# Network: testnet for build/demo (Constitution VI); flip to mainnet at cutover.

# ── Runtime ──
NODE_ENV=development
PORT=3004
# Allowed browser origin for CORS = your web app's URL (prod: your deployed web URL).
WEB_ORIGIN=http://localhost:3000

# Toggle the live Sui Stack. false/unset = mock adapters (dev). true ALSO requires
# the credentials below (and the live adapters per live-cutover.md).
SOUL_LIVE=false

# ── Supabase Postgres (metadata/index ONLY — never memory content) ──
# Get it: https://supabase.com → New project → Project Settings → Database →
# Connection string (URI). Looks like postgresql://postgres:...@...supabase.co:5432/postgres
DATABASE_URL=

# ── Enoki: zkLogin + sponsored gas. Get keys at https://portal.enoki.mystenlabs.com ──
# PRIVATE key — server only, NEVER shipped to the browser:
ENOKI_SECRET_KEY=
# PUBLIC key (also set NEXT_PUBLIC_ENOKI_PUBLIC_KEY in apps/web):
ENOKI_PUBLIC_KEY=
# Google OAuth client id for zkLogin. Get it at https://console.cloud.google.com →
# APIs & Services → Credentials → OAuth 2.0 Client ID (Web). Set origins per Enoki's guide.
GOOGLE_CLIENT_ID=

# ── Sui network: testnet (build) or mainnet (production cutover) ──
SUI_NETWORK=testnet

# ── MemWal relayer + on-chain contract IDs ──
# Defaults below are the VERIFIED TESTNET values (config.ts also carries them per-network).
# RE-VERIFY against live MemWal docs at build time — they change during beta.
MEMWAL_RELAYER_URL=https://relayer-staging.memory.walrus.xyz
MEMWAL_ACCOUNT_REGISTRY=0xe80f2feec1c139616a86c9f71210152e2a7ca552b20841f2e192f99f75864437
MEMWAL_PACKAGE_ID=0xcf6ad755a1cdff7217865c796778fabe5aa399cb0cf2eba986f4b582047229c6

# ── Delegate-key custody ──
# 32-byte master key to encrypt delegate keys at rest (REQUIRED when NODE_ENV=production).
# Generate:  openssl rand -hex 32   (or)  bun -e "console.log(crypto.randomBytes(32).toString('hex'))"
SECRET_ENCRYPTION_KEY=

# ── Optional: raises GitHub import limit (60 → 5000 req/hr). Not required ──
# github.com → Settings → Developer settings → Personal access tokens (no scopes needed).
GITHUB_TOKEN=
